# ==========================================
# 辽大计算机系课程资源库（LNU-CS-Resource）
# 超强力 Git 忽略配置（防 100MB+ 大文件与敏感缓存）
# ==========================================

# ------------------------------------------
# 1. 强制阻断 GitHub 限制的超大二进制文件 (防止 PUSH 失败)
# ------------------------------------------
# 视频及录屏格式 (仓库内含大量大容量网课/录屏，极易超 100MB)
*.mp4
*.MOV
*.mov
*.avi
*.mkv
*.wmv
*.flv
*.gif

# 忽略常见大型系统、数据库及 IDE 安装包、归档压缩包 (开发者应从官网下载，不占源码库空间)
*.exe
*.msi
*.dmg
*.pkg
*.iso
*.rar
*.zip
*.7z
*.tar
*.gz
*.xz

# ------------------------------------------
# 2. 忽略编译输出与二进制库 (防仓库臃肿)
# ------------------------------------------
# C/C++ 编译产物
*.o
*.obj
*.out
*.app
# 动态库与执行程序
*.dll
*.so
*.dylib
*.class
*.jar
*.war

# ------------------------------------------
# 3. 忽略虚拟环境与依赖包 (Node/Python)
# ------------------------------------------
# Python 虚拟环境与缓存
.venv/
venv/
env/
ENV/
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# Node.js 依赖
node_modules/

# ------------------------------------------
# 4. 忽略 IDE 及系统专属配置
# ------------------------------------------
# JetBrains IDEs (IntelliJ IDEA, PyCharm, CLion 等)
.idea/
*.iml
*.iws

# Visual Studio Code
.vscode/
.history/

# Local assistant/tooling state
.claude/
.omc/

# 系统特定缓存
Thumbs.db
.DS_Store
ehthumbs.db

# Office/editor temporary files
~$*
*.bak
*.tmp
*.temp

# 内部改动记录（不随仓库公开）
codex.md
